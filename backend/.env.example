# Required: JWT secret key (min 32 chars). Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge.db

# Admin initial password (optional, generates random if empty)
ADMIN_INITIAL_PASSWORD=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Internal API secret for server-to-server communication (required)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SECRET=

# Debug mode (set to false in production)
DEBUG=false
